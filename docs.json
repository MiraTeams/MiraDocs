{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Mira Docs",
  "colors": {
    "primary": "#4f6bff",
    "light": "#6B82FF",
    "dark": "#3A51CC",
    "background": {
      "light": "#ffffff",
      "dark": "#1e1e1e"
    }
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "languages": [
      {
        "language": "en",
        "default": true,
        "tabs": [
          {
            "tab": "Guides",
            "groups": [
              {
                "group": "Getting started",
                "pages": [
                  "index",
                  "quickstart",
                  "development"
                ]
              },
              {
                "group": "Customization",
                "pages": [
                  "essentials/settings",
                  "essentials/navigation"
                ]
              },
              {
                "group": "Writing content",
                "pages": [
                  "essentials/markdown",
                  "essentials/code",
                  "essentials/images",
                  "essentials/reusable-snippets"
                ]
              },
              {
                "group": "AI tools",
                "pages": [
                  "ai-tools/cursor",
                  "ai-tools/claude-code",
                  "ai-tools/windsurf"
                ]
              }
            ]
          },
          {
            "tab": "API reference",
            "groups": [
              {
                "group": "API documentation",
                "pages": [
                  "api-reference/introduction"
                ]
              },
              {
                "group": "Endpoint examples",
                "pages": [
                  "api-reference/endpoint/get",
                  "api-reference/endpoint/create",
                  "api-reference/endpoint/delete",
                  "api-reference/endpoint/webhook"
                ]
              }
            ]
          }
        ]
      },
      {
        "language": "zh",
        "tabs": [
          {
            "tab": "指南",
            "groups": [
              {
                "group": "开始使用",
                "pages": [
                  "zh/index",
                  "zh/quickstart",
                  "zh/development"
                ]
              },
              {
                "group": "自定义",
                "pages": [
                  "zh/essentials/settings",
                  "zh/essentials/navigation"
                ]
              },
              {
                "group": "编写内容",
                "pages": [
                  "zh/essentials/markdown",
                  "zh/essentials/code",
                  "zh/essentials/images",
                  "zh/essentials/reusable-snippets"
                ]
              },
              {
                "group": "AI 工具",
                "pages": [
                  "zh/ai-tools/cursor",
                  "zh/ai-tools/claude-code",
                  "zh/ai-tools/windsurf"
                ]
              }
            ]
          },
          {
            "tab": "API 参考",
            "groups": [
              {
                "group": "API 文档",
                "pages": [
                  "zh/api-reference/introduction"
                ]
              },
              {
                "group": "接口示例",
                "pages": [
                  "zh/api-reference/endpoint/get",
                  "zh/api-reference/endpoint/create",
                  "zh/api-reference/endpoint/delete",
                  "zh/api-reference/endpoint/webhook"
                ]
              }
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Documentation",
          "href": "https://docs.mira.day",
          "icon": "book-open-cover"
        },
        {
          "anchor": "Blog",
          "href": "https://mira.day/blog",
          "icon": "newspaper"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@mira.day"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://mira.day"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/maboroshitech",
      "github": "https://github.com/MiraTeams",
      "linkedin": "https://linkedin.com/company/mira"
    }
  }
}
