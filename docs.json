{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Mira Docs",
  "colors": {
    "primary": "#4f6bff",
    "light": "#6B82FF",
    "dark": "#3A51CC"
  },
  "favicon": "/favicon.svg",
  "appearance": {
    "default": "system"
  },
  "fonts": {
    "family": "Inter",
    "heading": {
      "family": "Inter",
      "weight": 600
    }
  },
  "icons": {
    "library": "lucide"
  },
  "background": {
    "decoration": "gradient",
    "color": {
      "light": "#ffffff",
      "dark": "#0a0a0a"
    }
  },
  "styling": {
    "codeblocks": {
      "theme": {
        "light": "github-light",
        "dark": "github-dark"
      }
    }
  },
  "navigation": {
    "languages": [
      {
        "language": "en",
        "default": true,
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "getting-started/quickstart",
              "getting-started/account-setup"
            ]
          },
          {
            "group": "Concepts",
            "pages": [
              "concepts/how-mira-works",
              "concepts/tasks",
              "concepts/skills"
            ]
          },
          {
            "group": "Recruiting",
            "pages": [
              "recruiting/candidate-search",
              "recruiting/evaluation",
              "recruiting/communication"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "integrations/overview",
              "integrations/chrome-extension"
            ]
          },
          {
            "group": "Security",
            "pages": [
              "security/overview"
            ]
          }
        ]
      },
      {
        "language": "zh",
        "groups": [
          {
            "group": "开始使用",
            "pages": [
              "zh/getting-started/quickstart",
              "zh/getting-started/account-setup"
            ]
          },
          {
            "group": "核心概念",
            "pages": [
              "zh/concepts/how-mira-works",
              "zh/concepts/tasks",
              "zh/concepts/skills"
            ]
          },
          {
            "group": "招聘功能",
            "pages": [
              "zh/recruiting/candidate-search",
              "zh/recruiting/evaluation",
              "zh/recruiting/communication"
            ]
          },
          {
            "group": "集成",
            "pages": [
              "zh/integrations/overview",
              "zh/integrations/chrome-extension"
            ]
          },
          {
            "group": "安全与合规",
            "pages": [
              "zh/security/overview"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Documentation",
          "href": "https://docs.mira.day",
          "icon": "book-open-cover"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@mira.day"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "https://mira.day/task"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/maboroshitech",
      "github": "https://github.com/MiraTeams",
      "linkedin": "https://linkedin.com/company/mira"
    }
  }
}
